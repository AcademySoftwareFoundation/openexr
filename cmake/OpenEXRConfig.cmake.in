@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Threads are commonly required by dependencies and OpenEXR options; find them
# irrespective of OPENEXR_ENABLE_THREADING (which controls threaded request processing).
set(THREADS_PREFER_PTHREAD_FLAG ON)
find_dependency(Threads)

find_dependency(Imath)

if (@libdeflate_FOUND@)
  find_dependency(libdeflate)
endif()

if (@openjph_FOUND@)
  find_dependency(openjph)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/@PROJECT_NAME@Targets.cmake")
check_required_components("@PROJECT_NAME@")
